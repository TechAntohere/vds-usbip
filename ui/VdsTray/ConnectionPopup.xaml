<Window x:Class="VdsTray.ConnectionPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True" ResizeMode="NoResize"
        SizeToContent="WidthAndHeight" Opacity="0" Focusable="False"
        IsHitTestVisible="False">

  <Grid>
    <!-- FULL connection card -->
    <Border x:Name="ConnectionView" CornerRadius="18" Margin="12"
            Width="430" Height="240" Background="#FF272727"
            BorderBrush="#FF3C3C3C" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.55" Color="#000000"/>
        </Border.Effect>
        <Grid Margin="26,22,26,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left: title + status + controller image -->
            <StackPanel Grid.Column="0">
                <TextBlock x:Name="TitleText" Text="Dualsense" Foreground="#FFE8E8E8"
                           FontSize="28" FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                    <TextBlock x:Name="StatusText" Text="Connected" Foreground="#FF2F6BFF"
                               FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Ellipse Width="7" Height="7" Fill="#FF7A7A7A" Margin="10,2,10,0"
                             VerticalAlignment="Center"/>
                    <Border x:Name="BatteryBox" CornerRadius="6" Padding="8,1"
                            BorderBrush="#FF3FCF4A" BorderThickness="1.5" VerticalAlignment="Center">
                        <TextBlock x:Name="BatteryText" Text="75" Foreground="#FF3FCF4A"
                                   FontSize="16" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
                <Image x:Name="ControllerImage" Height="120" Margin="0,14,0,0"
                       HorizontalAlignment="Left" Stretch="Uniform"/>
            </StackPanel>

            <!-- Right: jack / mic / polling -->
            <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="0,0,2,4">
                <TextBlock Text="HEADPHONES" Foreground="#FF6E6E6E" FontSize="10" FontWeight="SemiBold"/>
                <TextBlock x:Name="JackText" Text="—" Foreground="#FFCFCFCF" FontSize="15" Margin="0,0,0,10"/>
                <TextBlock Text="MICROPHONE" Foreground="#FF6E6E6E" FontSize="10" FontWeight="SemiBold"/>
                <TextBlock x:Name="MicText" Text="—" Foreground="#FFCFCFCF" FontSize="15" Margin="0,0,0,10"/>
                <TextBlock Text="POLLING RATE" Foreground="#FF6E6E6E" FontSize="10" FontWeight="SemiBold"/>
                <TextBlock x:Name="HzText" Text="— Hz" Foreground="#FFCFCFCF" FontSize="15"/>
            </StackPanel>
        </Grid>
    </Border>

    <!-- MINI toast (jack/mic change) -->
    <Border x:Name="MiniView" CornerRadius="14" Margin="12" Visibility="Collapsed"
            Background="#FF272727" BorderBrush="#FF3C3C3C" BorderThickness="1"
            Padding="22,14" HorizontalAlignment="Right" VerticalAlignment="Bottom">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.5" Color="#000000"/>
        </Border.Effect>
        <StackPanel Orientation="Horizontal">
            <Ellipse Width="9" Height="9" Fill="#FF2F6BFF" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <TextBlock x:Name="MiniText" Text="" Foreground="#FFE8E8E8" FontSize="17"
                       FontWeight="SemiBold" VerticalAlignment="Center"/>
        </StackPanel>
    </Border>
  </Grid>
</Window>
