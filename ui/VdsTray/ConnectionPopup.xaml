<Window x:Class="VdsTray.ConnectionPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True" ResizeMode="NoResize"
        SizeToContent="WidthAndHeight" Opacity="0" Focusable="False"
        IsHitTestVisible="False">

  <Grid>
    <!-- FULL connection card -->
    <Border x:Name="ConnectionView" CornerRadius="15" Margin="12"
            Width="600" Height="420" Background="#FF272727"
            BorderBrush="#FF3C3C3C" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="26" ShadowDepth="0" Opacity="0.55" Color="#000000"/>
        </Border.Effect>
        <Grid Margin="30,26,30,26">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left: title, status, controller -->
            <Grid Grid.Column="0">
                <StackPanel VerticalAlignment="Top">
                    <TextBlock x:Name="TitleText" Text="Dualsense" Foreground="#FFE8E8E8"
                               FontSize="44" FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal" Margin="2,2,0,0">
                        <TextBlock x:Name="StatusText" Text="Connected" Foreground="#FF2F6BFF"
                                   FontSize="24" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Ellipse Width="7" Height="7" Fill="#FF7A7A7A" Margin="12,3,12,0"
                                 VerticalAlignment="Center"/>
                        <Border x:Name="BatteryBox" CornerRadius="6" Padding="9,1"
                                BorderBrush="#FF3FCF4A" BorderThickness="2" VerticalAlignment="Center">
                            <TextBlock x:Name="BatteryText" Text="75" Foreground="#FF3FCF4A"
                                       FontSize="17" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
                <Image x:Name="ControllerImage" Height="340" VerticalAlignment="Bottom"
                       HorizontalAlignment="Center" Margin="0,0,0,-46" Stretch="Uniform"/>
            </Grid>

            <!-- Right: info box + status circles -->
            <Grid Grid.Column="1" Width="215">
                <!-- Info box -->
                <Border VerticalAlignment="Top" CornerRadius="12" BorderBrush="#FF4A4A4A"
                        BorderThickness="1" Padding="0">
                    <StackPanel>
                        <Border Padding="18,14" BorderBrush="#FF4A4A4A" BorderThickness="0,0,0,1">
                            <Grid>
                                <TextBlock Text="Polling Rate:" Foreground="#FFDADADA" FontSize="18"/>
                                <TextBlock x:Name="PollingValue" Text="—" Foreground="#FF9AA0A6"
                                           FontSize="18" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>
                        <Border Padding="18,14">
                            <Grid>
                                <TextBlock Text="Color:" Foreground="#FFDADADA" FontSize="18"/>
                                <TextBlock x:Name="ColorValue" Text="White" Foreground="#FF9AA0A6"
                                           FontSize="18" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Status circles. Icon is a tintable Rectangle masked by the
                     PNG glyph so we can recolor it for on/off states. -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom"
                            HorizontalAlignment="Right">
                    <Grid Width="78" Height="78" Margin="0,0,18,0">
                        <Ellipse x:Name="HpCircle" Fill="#FFEDEDED"/>
                        <Rectangle x:Name="HpIcon" Width="40" Height="40" Fill="#FF1A1A1A">
                            <Rectangle.OpacityMask>
                                <ImageBrush x:Name="HpMask"/>
                            </Rectangle.OpacityMask>
                        </Rectangle>
                    </Grid>
                    <Grid Width="78" Height="78">
                        <Ellipse x:Name="MicCircle" Fill="#FFEDEDED"/>
                        <Rectangle x:Name="MicIcon" Width="40" Height="40" Fill="#FF1A1A1A">
                            <Rectangle.OpacityMask>
                                <ImageBrush x:Name="MicMask"/>
                            </Rectangle.OpacityMask>
                        </Rectangle>
                    </Grid>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>

    <!-- MINI toast (jack/mic change): a square with just the icon. -->
    <Border x:Name="MiniView" CornerRadius="15" Margin="12" Visibility="Collapsed"
            Background="#FF272727" BorderBrush="#FF3C3C3C" BorderThickness="1"
            Width="96" Height="96" HorizontalAlignment="Right" VerticalAlignment="Bottom">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.5" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Ellipse x:Name="MiniCircle" Width="66" Height="66" Fill="#FFEDEDED"/>
            <Rectangle x:Name="MiniIcon" Width="34" Height="34" Fill="#FF1A1A1A">
                <Rectangle.OpacityMask>
                    <ImageBrush x:Name="MiniMask"/>
                </Rectangle.OpacityMask>
            </Rectangle>
        </Grid>
    </Border>
  </Grid>
</Window>
