#!/bin/sh
set -e

DKMS_NAME="vds_hcd"
UNINSTALL_SERVICE="/usr/share/vds/uninstall-service.sh"

remove_all_dkms_versions() {
	dkms status -m "$DKMS_NAME" 2>/dev/null |
	while IFS= read -r line; do
		case "$line" in
		"$DKMS_NAME/"*)
			version=${line#"$DKMS_NAME"/}
			version=${version%%,*}
			version=${version%%:*}
			if [ -n "$version" ]; then
				dkms remove -m "$DKMS_NAME" -v "$version" --all || true
			fi
			;;
		esac
	done
}

case "$1" in
remove | deconfigure)
	if [ -x "$UNINSTALL_SERVICE" ]; then
		"$UNINSTALL_SERVICE" --stop --disable || true
	fi
	;;
upgrade)
	if [ -x "$UNINSTALL_SERVICE" ]; then
		"$UNINSTALL_SERVICE" --stop || true
	fi
	;;
esac

case "$1" in
remove | upgrade | deconfigure)
	remove_all_dkms_versions
	;;
esac

exit 0
