#!/bin/sh
set -e

DKMS_NAME="vds_hcd"
DKMS_VERSION="@DKMS_VERSION@"
UNINSTALL_SERVICE="/usr/share/vds/uninstall-service.sh"

case "$1" in
remove | deconfigure)
	if [ -x "$UNINSTALL_SERVICE" ]; then
		"$UNINSTALL_SERVICE" --stop --disable || true
	fi
	;;
upgrade)
	if [ -x "$UNINSTALL_SERVICE" ]; then
		"$UNINSTALL_SERVICE" --stop || true
	fi
	;;
esac

case "$1" in
remove | upgrade | deconfigure)
	if dkms status -m "$DKMS_NAME" -v "$DKMS_VERSION" 2>/dev/null | grep -Fq "$DKMS_NAME/$DKMS_VERSION"; then
		dkms remove -m "$DKMS_NAME" -v "$DKMS_VERSION" --all || true
	fi
	;;
esac

exit 0
